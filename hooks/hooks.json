{
  "description": "RGPD anonymisation: pseudonymise client names in prompts, restore real names in written documents",
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/anonymize.py\" encode",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/anonymize.py\" decode",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
