{
  "description": "RGPD anonymisation + rappels fiscaux proactifs",
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "__VENV_PYTHON__ \"${CLAUDE_PLUGIN_ROOT}/hooks/anonymize.py\" encode",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "__VENV_PYTHON__ \"${CLAUDE_PLUGIN_ROOT}/hooks/fiscal_alerts.py\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "__VENV_PYTHON__ \"${CLAUDE_PLUGIN_ROOT}/hooks/anonymize.py\" decode",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "__VENV_PYTHON__ \"${CLAUDE_PLUGIN_ROOT}/hooks/output_router.py\"",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
